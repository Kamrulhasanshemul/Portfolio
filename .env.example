# Supabase (public — safe to expose to the browser)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_KEY=your-supabase-anon-key

# Supabase (server-only — bypasses RLS, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Session signing secret (generate with: openssl rand -base64 32)
SESSION_SECRET=change-me
